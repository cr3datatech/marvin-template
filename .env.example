# MARVIN Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# INTEGRATIONS
# ============================================

# Google Workspace (for Gmail, Calendar, Drive)
# Get these from Google Cloud Console or ask your admin
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Atlassian (for Jira, Confluence) - API Token Auth
# Get token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yoursite.atlassian.net
JIRA_EMAIL=your-bot@gmail.com
JIRA_API_TOKEN=

# ============================================
# API KEYS (for future integrations)
# ============================================

# Notion
NOTION_API_KEY=

# Linear
LINEAR_API_KEY=

# Slack
SLACK_BOT_TOKEN=

# OpenAI (if using for specific skills)
OPENAI_API_KEY=

# ============================================
# CUSTOM
# ============================================

# Add your own keys here as needed
# MY_SERVICE_API_KEY=
